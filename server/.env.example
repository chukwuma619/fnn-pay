# Copy to .env and fill in secrets:
#   cp .env.example .env

PORT=3001
NODE_ENV=development

# Neon (hosted) or local Postgres
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# DATABASE_URL=postgresql://fnnpay:PASSWORD@localhost:5432/fnnpay

# Auth (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET=change-me-use-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# 32+ byte secret for encrypting payment preimages (generate with: openssl rand -hex 32)
FNNPAY_SECRET_KEY=change-me-use-openssl-rand-hex-32

# Docker: http://fnn:8227 — local dev with exposed FNN RPC: http://127.0.0.1:8227
FNN_RPC_URL=http://fnn:8227
