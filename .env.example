# Copy to .env in the repo root and fill in secrets:
#   cp .env.example .env

# --- Postgres (Docker Compose local dev) ---
POSTGRES_USER=fnnpay
POSTGRES_PASSWORD=change-me-use-openssl-rand-hex-32
POSTGRES_DB=fnnpay

# --- Database (server) ---
# Neon (production / hosted): paste your pooled connection string from the Neon dashboard.
# Local Docker: postgresql://fnnpay:PASSWORD@localhost:5432/fnnpay (when postgres port is published)
# Compose default (inside stack): postgresql://fnnpay:PASSWORD@postgres:5432/fnnpay
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/fnnpay?sslmode=require

# --- FNN (Fiber Network Node) ---
# Password encrypts the FNN wallet key at rest inside the node data directory.
FIBER_SECRET_KEY_PASSWORD=change-me-strong-password
FNN_IMAGE=nervos/fiber:latest
FNN_LOG_LEVEL=info
# P2P port published to the host (Fiber gossip). RPC stays on the private Docker network.
FNN_P2P_PORT=8228

# --- FNNPay server ---
SERVER_PORT=3001
# 32+ byte secret for encrypting payment preimages (generate with: openssl rand -hex 32)
FNNPAY_SECRET_KEY=change-me-use-openssl-rand-hex-32
# Internal Docker URL — server talks to FNN over the private network, not the public internet.
FNN_RPC_URL=http://fnn:8227

# --- Web (optional, --profile web) ---
WEB_PORT=3000
VITE_API_URL=http://localhost:3001

# --- General ---
NODE_ENV=production
